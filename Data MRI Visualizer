        "import matplotlib.pyplot as plt\n",
        "from PIL import Image\n",
        "import numpy as np\n",
        "import random\n",
        "\n",
        "# Collect all image and mask paths that contain tumors\n",
        "tumor_images = []\n",
        "for patient in patients:\n",
        "    patient_path = os.path.join(base_path, patient)\n",
        "    # Skip if it's not a directory (e.g., data.csv)\n",
        "    if not os.path.isdir(patient_path):\n",
        "        continue\n",
        "\n",
        "    files = sorted(os.listdir(patient_path))\n",
        "    mask_files = [f for f in files if \"mask\" in f]\n",
        "\n",
        "    for mask_file in mask_files:\n",
        "        mask = np.array(Image.open(os.path.join(patient_path, mask_file)))\n",
        "        if mask.max() > 0:  # this mask actually has tumor in it\n",
        "            img_file = mask_file.replace(\"_mask\", \"\")\n",
        "            tumor_images.append((os.path.join(patient_path, img_file), os.path.join(patient_path, mask_file), patient))\n",
        "\n",
        "# Select a random image with a tumor\n",
        "if tumor_images:\n",
        "    random_img_path, random_mask_path, patient_id = random.choice(tumor_images)\n",
        "\n",
        "    img = np.array(Image.open(random_img_path))\n",
        "    mask = np.array(Image.open(random_mask_path))\n",
        "\n",
        "    fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
        "    axes[0].imshow(img)\n",
        "    axes[0].set_title(\"MRI Scan\")\n",
        "    axes[1].imshow(mask, cmap=\"gray\")\n",
        "    axes[1].set_title(\"Tumor Mask\")\n",
        "    axes[2].imshow(img)\n",
        "    axes[2].imshow(mask, cmap=\"Reds\", alpha=0.4)\n",
        "    axes[2].set_title(\"Overlay\")\n",
        "    plt.show()\n",
        "\n",
        "    print(f\"Patient: {patient_id}\")\n",
        "    print(f\"Image shape: {img.shape}\")\n",
        "    print(f\"Mask unique values: {np.unique(mask)}\")\n",
        "else:\n",
        "    print(\"No images with tumors found.\")"
      ],
